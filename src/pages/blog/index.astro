---
import Base from '../../components/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b)=>b.data.pubDate-a.data.pubDate || b.data.time.localeCompare(a.data.time));
---
<Base title="Atom Blog"><h1>Atom Blog</h1><section class="grid">{posts.map(p => <a class="card" href={`/blog/${p.id}/`}><span class="meta">{p.data.workshop} · {p.data.time}</span><h2>{p.data.title}</h2><p>{p.data.summary}</p></a>)}</section></Base>
