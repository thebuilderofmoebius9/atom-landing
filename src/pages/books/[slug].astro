---
import Base from '../../components/Base.astro';
import PdfReader from '../../components/PdfReader.jsx';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { slug: book.id }, props: { book } }));
}

const { book } = Astro.props;
const { Content } = await render(book);
---
<Base title={`${book.data.title} — Atom Books`} schema={[{
  '@context': 'https://schema.org', '@type': 'Book', name: book.data.title, description: book.data.summary,
  url: `https://atom.buildwithoracle.com/books/${book.id}/`, inLanguage: ['th', 'en'], author: { '@type': 'Person', name: 'Atom Oracle' },
  encoding: [{ '@type': 'MediaObject', encodingFormat: 'application/pdf', contentUrl: `https://atom.buildwithoracle.com${book.data.pdf}` }]
}, {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Books', item: 'https://atom.buildwithoracle.com/books/' },
    { '@type': 'ListItem', position: 2, name: book.data.title, item: `https://atom.buildwithoracle.com/books/${book.id}/` }
  ]
}]}>
  <article class="prose">
    <p><a href="/books/">← กลับหน้าหนังสือ</a></p>
    <h1>{book.data.title}</h1>
    <p class="subtitle">{book.data.summary}</p>
    {book.data.cover && <img class="book-cover" src={book.data.cover} alt={`ปกหนังสือ ${book.data.title}`} loading="lazy" />}
    <Content />
  </article>

  <section class="card" aria-labelledby="book-files">
    <h2 id="book-files">ไฟล์ต้นฉบับและ PDF</h2>
    <p>อ่านเนื้อหาด้านบนให้จบในเว็บก่อน ถ้าต้องการให้ AI อ่านต่อหรือคัดลอก Markdown ให้ใช้ลิงก์ GitHub นี้ก่อนดาวน์โหลด PDF</p>
    <p class="book-actions">
      <a href={book.data.source} target="_blank" rel="noreferrer">Markdown ที่ GitHub / ออกนอกเว็บ</a>
      <a class="button" href={book.data.pdf} download>Download PDF</a>
      <a class="button secondary" href="#pdf-preview">ดูตัวอย่าง PDF</a>
    </p>
    <h3 id="pdf-preview">Preview PDF</h3>
    <p>PDF เป็นฉบับจัดหน้าไว้ preview และ download หลังจากอ่าน HTML แล้ว</p>
    <PdfReader client:load pdf={book.data.pdf} />
  </section>
</Base>
