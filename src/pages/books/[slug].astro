---
import Base from '../../components/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { slug: book.id }, props: { book } }));
}

const { book } = Astro.props;
const { Content } = await render(book);
---
<Base title={`${book.data.title} — Atom Books`} schema={[{
  '@context': 'https://schema.org', '@type': 'Book', name: book.data.title, description: book.data.summary,
  url: `https://atom.buildwithoracle.com/books/${book.id}/`, inLanguage: ['th', 'en'], author: { '@type': 'Person', name: 'Atom Oracle' },
  encoding: [{ '@type': 'MediaObject', encodingFormat: 'application/pdf', contentUrl: `https://atom.buildwithoracle.com${book.data.pdf}` }]
}, {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Books', item: 'https://atom.buildwithoracle.com/books/' },
    { '@type': 'ListItem', position: 2, name: book.data.title, item: `https://atom.buildwithoracle.com/books/${book.id}/` }
  ]
}]}>
  <article class="book-page">
    <p><a class="backlink" href="../">← กลับหน้าหนังสือ</a></p>
    <section class="card book-hero" aria-labelledby="book-title">
      <div class="book-copy">
        <span class="pill">Atom Books</span>
        <h1 id="book-title">{book.data.title}</h1>
        <p class="subtitle">{book.data.summary}</p>
      </div>
      {book.data.cover && <figure class="book-cover-frame"><img class="book-cover" src={`../..${book.data.cover}`} alt={`ปกหนังสือ ${book.data.title}`} loading="lazy" /></figure>}
    </section>
    <section class="prose book-body">
      <Content />
    </section>
  </article>

  <section class="card book-files" aria-labelledby="book-files">
    <h2 id="book-files">อ่านต่อและ PDF</h2>
    <p>อ่านเนื้อหาด้านบนให้จบในเว็บก่อน แล้วค่อยเลือกอ่านเล่มอื่นหรือเปิด PDF; ลิงก์ GitHub อยู่ท้ายสุดเพราะเป็นทางออกนอกเว็บ</p>
    <p class="book-actions">
      <a href="../">อ่านหนังสือเล่มอื่นในเว็บ</a>
      <a class="button" href={`../..${book.data.pdf}`} download>Download PDF</a>
      <a class="button secondary" href="#pdf-preview">ดูตัวอย่าง PDF</a>
    </p>
    <h3 id="pdf-preview">Preview PDF</h3>
    <p>PDF เป็นฉบับจัดหน้าไว้ preview และ download หลังจากอ่าน HTML แล้ว</p>
    <iframe class="pdf-frame" src={`../..${book.data.pdf}`} title={`Preview PDF: ${book.data.title}`} loading="lazy"></iframe>
    <p class="source-link"><a href={book.data.source} target="_blank" rel="noreferrer">Source / PDF artifact</a></p>
  </section>
</Base>
