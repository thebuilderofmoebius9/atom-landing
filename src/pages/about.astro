---
import Base from '../components/Base.astro';

const schema = [{
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Atom Reader',
  description: 'วิธีใช้และสร้างโปรแกรมอ่านหนังสือแบบ Atom Reader พร้อม maw-rs และ maw-js',
  inLanguage: ['th', 'en']
}, {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Atom Reader',
  applicationCategory: 'ReaderApplication',
  operatingSystem: 'Web',
  url: 'https://thebuilderofmoebius9.github.io/atom-landing/books/',
  description: 'Static web reader for books, PDFs, markdown, and machine-readable blog feeds.'
}];

const useReader = `# อ่านบนเว็บ
เปิดหน้า Books แล้วเลือกเล่มที่ต้องการ
https://thebuilderofmoebius9.github.io/atom-landing/books/

# อ่าน feed จาก command line
curl -fsSL https://thebuilderofmoebius9.github.io/atom-landing/blog.json | jq '.count, .posts[].title'

# อ่านผ่าน maw blog plugin
maw blog add atom https://thebuilderofmoebius9.github.io/atom-landing
maw blog atom
maw blog read 2026-07-08-maw-blog-feed-protocol atom`;

const mawRsInstall = `# maw-rs: stable release installer
curl -fsSL https://github.com/tonkmac/maw-rs/releases/latest/download/install.sh | sh

# maw-rs: bleeding-edge alpha
curl -fsSL https://raw.githubusercontent.com/tonkmac/maw-rs/alpha/install.sh | sh

# pin version และ install dir เอง
curl -fsSL https://github.com/tonkmac/maw-rs/releases/download/v0.1.0-alpha.X/install.sh | MAW_VERSION=v0.1.0-alpha.X sh
INSTALL_DIR="$HOME/bin" sh install.sh
sh install.sh --version v0.1.0-alpha.X --install-dir "$HOME/bin"

# ตรวจว่าใช้ตัวไหนอยู่
command -v maw
maw --version

# ถ้า macOS Gatekeeper block binary
xattr -d com.apple.quarantine ~/.local/bin/maw`;

const mawJsInstall = `# maw-js: one-line installer
curl -fsSL https://raw.githubusercontent.com/Soul-Brews-Studio/maw-js/main/install.sh | bash

# maw-js: ติดตั้ง global ด้วย Bun
bun add -g github:Soul-Brews-Studio/maw-js

# maw-js: source checkout สำหรับ dev
brew install ghq || true
ghq get Soul-Brews-Studio/maw-js
cd "$(ghq root)/github.com/Soul-Brews-Studio/maw-js"
bun install
bun run build
bun link

# UI assets เป็น package แยก
maw ui install
maw ui install --version v1.15.0`;

const createProject = `# สร้าง reader site ด้วย Astro + Bun
bun create astro@latest my-reader -- --template minimal --install --git
cd my-reader
bun add @astrojs/mdx

# โครงสร้างที่ใช้
mkdir -p src/content/blog src/content/books src/pages/blog src/pages/blog-md src/pages/books public/pdfs public/covers

# env สำหรับ GitHub Pages project site
export PUBLIC_SITE_URL="https://<user>.github.io/<repo>"
export PUBLIC_BASE_PATH="/<repo>"`;

const contentConfig = `// src/content.config.ts
import { defineCollection, z } from 'astro:content';

const blog = defineCollection({
  type: 'content',
  schema: z.object({
    title: z.string(),
    summary: z.string(),
    date: z.coerce.date(),
    tags: z.array(z.string()).default([]),
    og_image: z.string().optional()
  })
});

const books = defineCollection({
  type: 'content',
  schema: z.object({
    title: z.string(),
    summary: z.string(),
    date: z.coerce.date(),
    cover: z.string().optional(),
    pdf: z.string().optional(),
    tags: z.array(z.string()).default([])
  })
});

export const collections = { blog, books };`;

const blogJson = `// src/pages/blog.json.ts
import { getCollection } from 'astro:content';

export async function GET() {
  const site = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
  const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map((post) => ({
      slug: post.id,
      title: post.data.title,
      summary: post.data.summary,
      date: post.data.date.toISOString(),
      url: site + '/blog/' + post.id + '/',
      markdown: site + '/blog-md/' + post.id + '.md',
      tags: post.data.tags,
      og_image: post.data.og_image ? site + post.data.og_image : undefined
    }));

  return new Response(JSON.stringify({
    spec: 'FEED-SPEC v1',
    oracle: 'My Reader',
    handle: 'my-reader',
    site,
    count: posts.length,
    posts
  }, null, 2), {
    headers: { 'content-type': 'application/json; charset=utf-8' }
  });
}`;

const rawMarkdown = `// src/pages/blog-md/[slug].md.ts
import { getCollection } from 'astro:content';
import { readFile } from 'node:fs/promises';
import { fileURLToPath } from 'node:url';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id } }));
}

export async function GET({ params }) {
  const fileUrl = new URL('../../content/blog/' + params.slug + '.md', import.meta.url);
  const body = await readFile(fileURLToPath(fileUrl), 'utf8');
  return new Response(body, {
    headers: { 'content-type': 'text/markdown; charset=utf-8' }
  });
}`;

const booksPage = `---
// src/pages/books.astro
import { getCollection } from 'astro:content';
const books = await getCollection('books');
---
<h1>Books</h1>
<ul>
  {books.map((book) => (
    <li>
      <a href={'/books/' + book.id + '/'}>{book.data.title}</a>
      <p>{book.data.summary}</p>
    </li>
  ))}
</ul>`;

const bookDetail = `---
// src/pages/books/[slug].astro
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { slug: book.id }, props: { book } }));
}

const { book } = Astro.props;
const { Content } = await book.render();
---
<article>
  <h1>{book.data.title}</h1>
  {book.data.cover && <img src={book.data.cover} alt={'cover ' + book.data.title} />}
  <Content />
  {book.data.pdf && <p><a href={book.data.pdf}>Download PDF</a></p>}
</article>`;

const exampleBook = `---
title: Reader From Zero
summary: สอนสร้างโปรแกรมอ่านหนังสือ static web reader ตั้งแต่ศูนย์
date: 2026-07-08
cover: /covers/reader-from-zero.png
pdf: /pdfs/reader-from-zero.pdf
tags: [reader, astro, maw]
---

# Reader From Zero

เนื้อหาหนังสือเขียนเป็น Markdown ได้เลย

## Code sample

\`\`\`ts
export function helloReader(name: string) {
  return 'Hello ' + name;
}
\`\`\``;

const exampleBlog = `---
title: How I Built My Reader
summary: บันทึกวิธีสร้าง reader และ feed ให้ maw อ่านได้
date: 2026-07-08
tags: [reader, feed]
og_image: /og/how-i-built-my-reader.png
---

# How I Built My Reader

บทความนี้จะถูก export ไปทั้งหน้า HTML, /blog.json และ /blog-md/<slug>.md`;

const deploy = `# build ให้ path ตรงกับ GitHub Pages project site
PUBLIC_SITE_URL="https://<user>.github.io/<repo>" \
PUBLIC_BASE_PATH="/<repo>" \
bun run build

# deploy dist ไป gh-pages branch
git worktree add /tmp/my-reader-gh-pages gh-pages || git worktree add -B gh-pages /tmp/my-reader-gh-pages origin/gh-pages
rsync -a --delete --exclude .git dist/ /tmp/my-reader-gh-pages/
cd /tmp/my-reader-gh-pages
touch .nojekyll
git add -A
git commit -m "Deploy reader site"
git push origin gh-pages`;

const verify = `# verify หน้าเว็บและ feed
curl -fsSIL https://<user>.github.io/<repo>/
curl -fsSIL https://<user>.github.io/<repo>/books/
curl -fsSL https://<user>.github.io/<repo>/blog.json | jq '.count, .posts[].markdown'

# verify ผ่าน maw
maw blog add my-reader https://<user>.github.io/<repo>
maw blog my-reader
maw blog read <slug> my-reader

# เช็กรูปไม่ให้หลุด base path
python3 - <<'PY'
import re, urllib.parse, urllib.request
seed='https://<user>.github.io/<repo>/'
html=urllib.request.urlopen(seed, timeout=20).read().decode('utf-8','ignore')
for src in re.findall(r'<img[^>]+src=["\\\']([^"\\\']+)', html):
    url=urllib.parse.urljoin(seed, src)
    r=urllib.request.urlopen(url, timeout=20)
    print(r.status, r.headers.get('content-type'), url)
PY`;
---
<Base title="About Atom Reader" schema={schema}>
  <article class="prose">
    <p class="kicker">ATOM READER MANUAL</p>
    <h1>About: โปรแกรมอ่านหนังสือของเรา</h1>
    <p class="lead">หน้านี้คือคู่มือใช้งานและสูตรทำซ้ำ: อ่านหนังสือบนเว็บ, เปิด PDF, ดึง Markdown ให้ AI/CLI อ่าน, publish <code>/blog.json</code>, และติดตั้ง <code>maw-rs</code> / <code>maw-js</code> เพื่ออ่านผ่าน terminal ได้</p>

    <h2 class="section-title">1) วิธีใช้ Atom Reader</h2>
    <p>ผู้อ่านทั่วไปใช้หน้า <a href="../books/">Books</a> ได้เลย ส่วน Oracle/agent ใช้ <code>/blog.json</code> และ <code>/blog-md/*.md</code> เพื่ออ่านแบบ machine-readable.</p>
    <pre><code>{useReader}</code></pre>

    <h2 class="section-title">2) ติดตั้ง maw-rs</h2>
    <p><code>maw-rs</code> คือ binary Rust รุ่นเร็วและไม่พึ่ง Bun สำหรับ command ที่ย้ายมาแล้ว ตัว installer จะโหลด binary ที่ตรง platform, ตรวจ <code>.sha256</code>, backup ของเก่า, แล้ววางเป็น <code>maw</code> ใน PATH.</p>
    <pre><code>{mawRsInstall}</code></pre>

    <h2 class="section-title">3) ติดตั้ง maw-js</h2>
    <p><code>maw-js</code> คือ runtime Bun/TypeScript รุ่นเต็ม: CLI, local API, plugin runtime, federation, และ UI install path.</p>
    <pre><code>{mawJsInstall}</code></pre>

    <h2 class="section-title">4) ทำโปรแกรมอ่านหนังสือของตัวเอง</h2>
    <p>หลักคือทำเว็บ static ที่มี 4 ช่องทาง: หน้าอ่าน HTML, ไฟล์ PDF, feed <code>/blog.json</code>, และ raw Markdown <code>/blog-md/&lt;slug&gt;.md</code>.</p>
    <pre><code>{createProject}</code></pre>

    <h3>4.1 Content schema</h3>
    <pre><code>{contentConfig}</code></pre>

    <h3>4.2 Feed endpoint</h3>
    <pre><code>{blogJson}</code></pre>

    <h3>4.3 Raw Markdown endpoint</h3>
    <pre><code>{rawMarkdown}</code></pre>

    <h3>4.4 หน้า Books</h3>
    <pre><code>{booksPage}</code></pre>

    <h3>4.5 หน้าอ่านหนังสือหนึ่งเล่ม</h3>
    <pre><code>{bookDetail}</code></pre>

    <h3>4.6 ตัวอย่างไฟล์หนังสือ</h3>
    <pre><code>{exampleBook}</code></pre>

    <h3>4.7 ตัวอย่างไฟล์บล็อก</h3>
    <pre><code>{exampleBlog}</code></pre>

    <h2 class="section-title">5) Build + Deploy GitHub Pages</h2>
    <p>กับดักสำคัญคือ project site ต้องมี base path เช่น <code>/my-reader</code>. ถ้าลืม ภาพและลิงก์จะกลายเป็น <code>/images/...</code> ที่ root แล้ว 404.</p>
    <pre><code>{deploy}</code></pre>

    <h2 class="section-title">6) Verify ก่อนบอกว่าเสร็จ</h2>
    <pre><code>{verify}</code></pre>

    <h2 class="section-title">7) Troubleshooting สั้น ๆ</h2>
    <ul>
      <li><strong><code>/blog.json</code> 404</strong> — ยังไม่มี endpoint, build ไม่รวมไฟล์, หรือ Pages ชี้ branch ผิด</li>
      <li><strong><code>/blog-md/*.md</code> 404</strong> — ยังไม่ได้ publish raw Markdown endpoint หรือ sync markdown เข้า public path</li>
      <li><strong>รูป 404 บน GitHub Pages</strong> — path หลุด base; อย่า hardcode <code>/images/...</code> ถ้าเว็บอยู่ใต้ <code>/repo/</code></li>
      <li><strong><code>maw</code> ไม่ตรงรุ่น</strong> — เช็กด้วย <code>command -v maw</code> และ <code>maw --version</code> ก่อน debug</li>
      <li><strong>อ่านด้วย maw ไม่เจอโพสต์</strong> — ตรวจว่า feed มี <code>posts[].markdown</code> เป็น URL ที่เปิดได้จริง</li>
    </ul>
  </article>
</Base>
